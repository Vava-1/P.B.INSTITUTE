# ─────────────────────────────────────────────────────────────
# Pacemaker Institute — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` for local dev, or set these in Railway
# (Service → Variables → Raw Editor). All variables below are REQUIRED
# in production unless marked OPTIONAL.

# ─── Database ───────────────────────────────────────────────
# MySQL connection string. On Railway, use the "MySQL" plugin and
# reference its `MYSQL_URL` variable here.
DATABASE_URL=mysql://user:password@host:3306/pacemaker

# ─── Auth / OAuth ───────────────────────────────────────────
# The OAuth 2.0 Identity Provider (P.B.INSTITUTE Open Platform).
AUTH_URL=https://auth.example.com
OPEN_URL=https://open.example.com
APP_ID=your_oauth_app_id
APP_SECRET=your_oauth_client_secret

# SECURITY: separate secret for signing user session JWTs. MUST be a
# different value from APP_SECRET. Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_32_byte_random_hex_string

# OPTIONAL: the OAuth unionId that should be auto-promoted to "admin"
# on first sign-in. Leave empty in production unless you know what you're doing.
OWNER_UNION_ID=

# ─── Admin JWT ──────────────────────────────────────────────
# Signs admin JWTs (8h expiry). Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_byte_random_hex_string

# ─── Admin Seed (one-time bootstrap) ────────────────────────
# Only used by `npm run db:seed`. Creates the first super_admin user.
# NEVER commit real credentials. Use a strong password.
SEED_ADMIN_EMAIL=admin@pacemakerinstitute.ac.rw
SEED_ADMIN_NAME=System Administrator
SEED_ADMIN_PASSWORD=ChangeMe_StrongPassw0rd!

# ─── Frontend (exposed to browser via Vite) ─────────────────
VITE_AUTH_URL=https://auth.example.com
VITE_APP_ID=your_oauth_app_id

# ─── Email (Resend) ─────────────────────────────────────────
# Get a key at https://resend.com. OPTIONAL in dev (emails silently skipped).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── MTN MoMo API ───────────────────────────────────────────
# From the MTN MoMo Developer Portal (Collections product).
MTN_MOMO_SUBSCRIPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REQUIRED in production. Auto-provisioned in dev if empty.
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
# Defaults to sandbox: https://sandbox.momodeveloper.mtn.com
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
# "sandbox" (default) or "production"
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=RWF
# Your public Railway URL — MTN calls this for payment webhooks.
MTN_MOMO_CALLBACK_HOST=https://your-app.up.railway.app

# ─── Analytics (OPTIONAL) ───────────────────────────────────
# Real GA4 measurement ID. If empty or contains "XXXX", analytics is disabled.
VITE_GA_ID=
